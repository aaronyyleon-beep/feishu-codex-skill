# Required
FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx

# Optional
CODEX_BIN=codex
CODEX_DEFAULT_CWD=/Users/linxiaoyi
CODEX_HOME=/Users/linxiaoyi/.codex
SESSION_STATE_FILE=.feishu_session_map.json
RESPONSE_STYLE=brief
ASSISTANT_SOUL=developer_engineer
ASSISTANT_AGENTS_FILE=AGENTS.md
ASSISTANT_SOUL_FILE=SOUL.md
LARK_CLI_BIN=lark-cli
DEFAULT_BACKEND=codex
LLM_REQUEST_TIMEOUT_SEC=60
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
PROJECT_MEMORY_MAX_CHARS=2400
PROJECT_DAILY_TAIL_LINES=24
PROJECT_MEMORY_AUTO_UPDATE=1
PROJECT_MEMORY_ENTRY_MAX_CHARS=280

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Gemini
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.0-flash

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Qwen (DashScope OpenAI-compatible endpoint)
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

STREAM_CHUNK_CHARS=800
STREAM_FLUSH_SEC=2.0
STREAM_SEND_INTERVAL_SEC=0.12
STREAM_PSEUDO_CHUNK_CHARS=32
STREAM_EDIT_IN_PLACE=1
STREAM_USE_MARKDOWN=1
STREAM_UPDATE_INTERVAL_SEC=0.25
STREAM_MAX_UPDATES_PER_MESSAGE=18
STREAM_MESSAGE_MAX_CHARS=4000
MERGE_WINDOW_SEC=0.3
STATUS_RECEIVED_TEXT=⏳ 已收到，正在思考...
STREAM_MARKDOWN_TITLE=

# Security
REQUIRE_P2P=0
ALLOWED_OPEN_IDS=
ALLOWED_CHAT_IDS=
BOT_OPEN_ID=
BOT_ALIASES=Maclaw
GROUP_REQUIRE_MENTION=1
BOT_MENTION_MAP=Maclaw:ou_xxx,OpsLens:ou_xxx
COMMAND_TOKEN=
ENABLE_RAW_CMD=0
RATE_LIMIT_PER_MINUTE=20
MAX_USER_TEXT_CHARS=8000
SEND_UNAUTHORIZED_NOTICE=0
UNAUTHORIZED_NOTICE_TEXT=⛔️ 未授权访问
RATE_LIMIT_NOTICE_TEXT=⏱ 请求过于频繁，请稍后再试
LOG_LEVEL=INFO
